# DecisionFlow AI - environment configuration
# Provider is Gemini. Leave GOOGLE_API_KEY blank to run in offline MOCK mode
# (agents return realistic deterministic output so the demo always works).
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Set to "true" to force mock mode even if a key is present.
FORCE_MOCK=false
